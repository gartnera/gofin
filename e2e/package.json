{
  "name": "@gofin/e2e",
  "version": "0.0.0",
  "private": true,
  "description": "Playwright end-to-end scripts that drive the bundled Jellyfin web client against gofin to verify browse + playback and surface fetch errors.",
  "type": "module",
  "packageManager": "pnpm@10.33.0",
  "scripts": {
    "crawl": "tsx src/scenarios/crawl.ts",
    "playback": "tsx src/scenarios/playback.ts",
    "install:browser": "playwright install chromium",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "playwright": "1.56.1",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
